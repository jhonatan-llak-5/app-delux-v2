# ============================================================================
# Delux — Variables de PRODUCCIÓN
# Copia este archivo a .env (en la carpeta del entorno) y rellena los valores.
#   cp .env.prod.example .env
# docker compose lo autocarga; corre:  docker compose -f docker-compose.prod.yml up -d --build
# ============================================================================

# ── Entorno: define el sufijo de contenedores e imágenes (delux_backend_staging, ...) ──
APP_ENV=staging

# ── Puerto del host donde se publica la web (el 80 está ocupado en tu VPS) ──
WEB_PORT=8080

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
# Genera una con: python -c "import secrets;print(secrets.token_urlsafe(50))"
SECRET_KEY=CAMBIA-ESTA-CLAVE-LARGA-Y-ALEATORIA
JWT_SECRET_KEY=CAMBIA-ESTE-JWT

# Hosts permitidos. Para empezar por IP, pon la IP pública del VPS.
# Cuando tengas dominio, agrégalo:  delux.midominio.com,www.delux.midominio.com
ALLOWED_HOSTS=TU_IP_DEL_VPS,localhost,127.0.0.1

# Solo necesario con dominio (para el admin de Django sobre HTTPS).
# Incluye el esquema:  https://delux.midominio.com
CSRF_TRUSTED_ORIGINS=

# HTTPS: déjalo en False mientras accedas por http://IP:puerto.
# Ponlo en True cuando ya tengas dominio + certificado TLS (en tu nginx del :443).
SECURE_SSL=False
SECURE_SSL_REDIRECT=False

# ── Base de datos (interna, contenedor postgres) ────────────────────────────
DB_NAME=delux
DB_USER=delux
DB_PASSWORD=CAMBIA-ESTA-CLAVE-DB
DB_HOST=postgres
DB_PORT=5432

# ── Redis (interno) ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── URLs / CORS ─────────────────────────────────────────────────────────────
# Mismo origen que la web; con dominio: https://delux.midominio.com
FRONTEND_URL=http://TU_IP_DEL_VPS:8080
CORS_ALLOWED_ORIGINS=http://TU_IP_DEL_VPS:8080

# ── Email (ajusta a tu proveedor SMTP cuando quieras enviar correos reales) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@delux.com

# ── Pagos PayPhone (opcional) ───────────────────────────────────────────────
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# ── Almacenamiento S3 (opcional). Si lo dejas vacío, se usan archivos locales
#    servidos por nginx (recomendado para empezar). ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ── Multi-tenant ────────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=delux

# ── Errores en producción (opcional) ────────────────────────────────────────
SENTRY_DSN=
